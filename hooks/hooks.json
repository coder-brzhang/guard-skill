{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash '${CLAUDE_SKILL_DIR}/../../scripts/scan-skill.sh' '$(echo $TOOL_INPUT | jq -r .file_path // empty)' 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "FILE_PATH=$(echo $TOOL_INPUT | jq -r .file_path // empty); if [[ \"$FILE_PATH\" == *\".claude/skills\"* ]] || [[ \"$FILE_PATH\" == *\"SKILL.md\"* ]]; then bash '${CLAUDE_SKILL_DIR}/../../scripts/scan-skill.sh' \"$(dirname $FILE_PATH)\" 2>/dev/null; fi"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[🛡️ Guard] 技能安全监控已激活'"
          }
        ]
      }
    ]
  }
}
